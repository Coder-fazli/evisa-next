# Sanity CMS — required for build and content fetching.
# Copy this file to .env.local and fill in real values.

# Public Sanity project ID (found in your Sanity project settings / sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (e.g. "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Server-side Sanity API token (read access). Keep secret — do not prefix with NEXT_PUBLIC_.
SANITY_API_TOKEN=
